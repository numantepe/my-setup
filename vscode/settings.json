{
  "vim.leader": ",",
  "vim.useSystemClipboard": true,

  "vim.insertModeKeyBindings": [
    { "before": ["j", "j"], "after": ["<Esc>"] }
  ],

  "vim.normalModeKeyBindingsNonRecursive": [
    { "before": [",", "n"], "commands": ["workbench.view.explorer"] },
    { "before": [",", "m"], "commands": ["workbench.action.previousEditor"] },

    { "before": [",", "."], "commands": ["workbench.action.focusNextGroup"] },
    { "before": [",", "w"], "commands": ["workbench.action.focusAboveGroup"] },
    { "before": [",", "a"], "commands": ["workbench.action.focusLeftGroup"] },
    { "before": [",", "s"], "commands": ["workbench.action.focusBelowGroup"] },
    { "before": [",", "d"], "commands": ["workbench.action.focusRightGroup"] },

    { "before": ["H"], "commands": ["workbench.action.previousEditor"] },
    { "before": ["L"], "commands": ["workbench.action.nextEditor"] },

    { "before": [",", "t"], "commands": ["workbench.action.terminal.toggleTerminal"] }
  ]
}
